<?xml version="1.0" encoding="utf-8"?>
<!--
  Web.Release.config — XDT transform applied when publishing with Configuration=Release.
  This file is NOT deployed; it patches Web.config at publish time.
  Docs: https://go.microsoft.com/fwlink/?LinkId=125889
-->
<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">

  <connectionStrings>
    <!--
      Replace the LocalDB connection string with the production SQL Server string.
      Set the real values via environment variables or a secrets manager before publishing;
      never commit production credentials to source control.

      Example (Windows auth):
        Server=PROD_SERVER;Database=InvestorPortal;Integrated Security=True;

      Example (SQL auth):
        Server=PROD_SERVER;Database=InvestorPortal;User Id=ip_app;Password=REPLACE_ME;
    -->
    <add name="InvestorPortalDB"
         connectionString="Server=PROD_SERVER;Database=InvestorPortal;Integrated Security=True;"
         providerName="System.Data.SqlClient"
         xdt:Transform="SetAttributes"
         xdt:Locator="Match(name)" />
  </connectionStrings>

  <system.web>
    <!-- Turn off debug symbols and bytecode inclusion in responses -->
    <compilation xdt:Transform="SetAttributes" debug="false" />

    <!-- Redirect runtime errors to Error.aspx; hide details from clients -->
    <customErrors mode="On" defaultRedirect="~/Pages/Error.aspx"
                  xdt:Transform="Insert" />

    <!-- Require SSL for session cookies in production -->
    <httpCookies httpOnlyCookies="true" requireSSL="true"
                 xdt:Transform="SetAttributes" />
  </system.web>

  <system.webServer>
    <!-- Suppress IIS detailed errors from reaching the browser -->
    <httpErrors existingResponse="Replace" xdt:Transform="Insert">
      <remove statusCode="404" />
      <error statusCode="404" path="/Pages/Error.aspx" responseMode="ExecuteURL" />
      <remove statusCode="500" />
      <error statusCode="500" path="/Pages/Error.aspx" responseMode="ExecuteURL" />
    </httpErrors>
  </system.webServer>

</configuration>
